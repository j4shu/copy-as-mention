{
  "name": "copy-as-mention",
  "displayName": "Copy as Mention",
  "description": "Copy the active file and selected lines as a Claude Code @-mention (e.g. \"@src/foo.txt#1-39\") to the clipboard.",
  "version": "0.0.1",
  "publisher": "j4shu",
  "repository": {
    "type": "git",
    "url": "https://github.com/j4shu/copy-as-mention.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "copy",
    "clipboard",
    "context",
    "line numbers",
    "reference"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copyAsMention.copyRelative",
        "title": "Copy as Mention: Relative",
        "category": ""
      },
      {
        "command": "copyAsMention.copyFileName",
        "title": "Copy as Mention: Filename",
        "category": ""
      },
      {
        "command": "copyAsMention.copyAbsolute",
        "title": "Copy as Mention: Absolute",
        "category": ""
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "copyAsMention.copyRelative",
          "when": "editorTextFocus",
          "group": "9_cutcopypaste"
        },
        {
          "command": "copyAsMention.copyFileName",
          "when": "editorTextFocus",
          "group": "9_cutcopypaste"
        },
        {
          "command": "copyAsMention.copyAbsolute",
          "when": "editorTextFocus",
          "group": "9_cutcopypaste"
        }
      ]
    },
    "keybindings": [
      {
        "command": "copyAsMention.copyRelative",
        "key": "ctrl+alt+c",
        "mac": "cmd+alt+c",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "Copy as Mention",
      "properties": {
        "copyAsMention.showStatusBarMessage": {
          "type": "boolean",
          "default": true,
          "description": "Show a brief status bar confirmation after copying."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0"
  }
}